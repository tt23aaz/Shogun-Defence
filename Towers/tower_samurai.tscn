# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	hide()

func _draw():
	var cen = Vector2(0,0)
	var rad = get_parent().get_parent().range
	var col = Color(1,0,0,0.3)
	draw_circle(cen,rad,col)
"

